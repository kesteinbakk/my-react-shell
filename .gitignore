node_modules/
# dist/ is committed — it ships to git-dep consumers, who run no build on install.
# See docs/guides/distribution-model.md. (dist-harness/ is the harness build; never shipped.)
dist-harness/
.env
.env.*
!.env.example
logs/
# Local agent tooling. Most of .claude/ is machine-local (settings.json hooks an
# absolute path outside the repo) or skill-synced/generated (skills/, launch.json,
# worktrees/ — regenerated), so those stay out. Hand-authored agent role files under
# .claude/agents/ ARE source and are tracked.
.claude/*
!.claude/agents/
.DS_Store

# generated
*.tsbuildinfo
.tanstack/
# TanStack route tree — regenerated by the router plugin on `pnpm dev`/`build`.
# Harness-only artifact (consumers don't receive the harness routes).
src/routeTree.gen.ts
