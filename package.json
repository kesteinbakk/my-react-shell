{
  "name": "my-react-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React application foundation above shadcn/ui — app-shell, providers, i18n, and cross-app contracts for Vite + Convex SPAs.",
  "engines": {
    "node": "24.x"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth/convex": {
      "types": "./src/auth/convex-auth.tsx",
      "import": "./src/auth/convex-auth.tsx"
    },
    "./styles.css": "./src/index.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.170.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "convex": "^1.41.0",
    "@convex-dev/auth": "^0.0.94",
    "@auth/core": "^0.41.1"
  },
  "peerDependenciesMeta": {
    "@convex-dev/auth": {
      "optional": true
    },
    "@auth/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth/core": "0.41.1",
    "@convex-dev/auth": "0.0.94",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convex": "^1.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
