{
  "name": "my-react-shell",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "description": "Modular React foundation — optional, versioned drop-in modules (theme, providers, auth seam, i18n) for Vite + Convex SPAs. Consumed as a GitHub git-dependency.",
  "author": "Karl Erik Steinbakk <post@kesteinbakk.no>",
  "license": "ISC",
  "engines": {
    "node": "24.x"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./auth/convex": {
      "types": "./dist/auth/convex-auth.d.ts",
      "import": "./dist/auth/convex-auth.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./app-shell": {
      "types": "./dist/app-shell/index.d.ts",
      "import": "./dist/app-shell/index.js"
    },
    "./app-shell/styles.css": "./src/app-shell/app-shell.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/styles.css": "./src/components/components.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./styles.css": "./src/index.css",
    "./fonts/inter.css": "./src/fonts/inter.css",
    "./fonts/geist.css": "./src/fonts/geist.css"
  },
  "files": [
    "dist",
    "src/**/*.css",
    "docs/specifications/api-reference.md",
    "docs/guides"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json",
    "build:lib:watch": "node scripts/dev-watch.mjs",
    "sync:themes": "node scripts/sync-themes.mjs",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "release": "node scripts/release.mjs",
    "setup:hooks": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8"
  },
  "peerDependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
