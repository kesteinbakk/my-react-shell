{
  "name": "my-react-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modular React foundation — optional, versioned drop-in modules (theme, providers, auth seam, i18n) for Vite + Convex SPAs. Consumed as a Bitbucket git-dependency.",
  "engines": {
    "node": "24.x"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./auth/convex": {
      "types": "./dist/auth/convex-auth.d.ts",
      "import": "./dist/auth/convex-auth.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./app-shell": {
      "types": "./dist/app-shell/index.d.ts",
      "import": "./dist/app-shell/index.js"
    },
    "./app-shell/styles.css": "./src/app-shell/app-shell.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/styles.css": "./src/components/components.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./styles.css": "./src/index.css"
  },
  "files": [
    "dist",
    "src/index.css",
    "src/styles",
    "src/app-shell/app-shell.css",
    "src/components/components.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json",
    "build:lib:watch": "tsc -p tsconfig.lib.json --watch",
    "prepare": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "setup:hooks": "git config core.hooksPath .githooks"
  },
  "peerDependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@tanstack/react-router": "^1.170.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    },
    "@convex-dev/auth": {
      "optional": true
    },
    "@auth/core": {
      "optional": true
    },
    "@radix-ui/react-dialog": {
      "optional": true
    },
    "@radix-ui/react-dropdown-menu": {
      "optional": true
    },
    "@radix-ui/react-popover": {
      "optional": true
    },
    "@radix-ui/react-select": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "class-variance-authority": {
      "optional": true
    },
    "clsx": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth/core": "0.41.1",
    "@convex-dev/auth": "0.0.94",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
